# Copy this file to `.env` and fill in your own values.
# The `.env` file is gitignored and must NEVER be committed.

# Password required for the gallery login screen.
# Pick any value you like (numeric PIN, passphrase, etc.).
GALLERY_PASSWORD=change-me

# Optional: port the server listens on (default 5000)
# PORT=5000

# Cloudinary credentials (required for image storage).
# Find these on https://cloudinary.com/console under "Product Environment Credentials".
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
